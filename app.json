        },
        {
          "id": "add_devices",
          "template": "add_devices"
        }
      ],
      "images": {
        "small": "./drivers/aqara_double/assets/images/small.png",
        "large": "./drivers/aqara_double/assets/images/large.png",
        "xlarge": "./drivers/aqara_double/assets/images/xlarge.png"
      }
    }
  ]
}
