          "aqara"
        ],
        "productId": [
          "lumi.plug.maeu02",
          "lumi.plug.sp_euc02",
          "SP-EUC02"
        ],
        "endpoints": {
          "1": {
            "clusters": [0, 2, 3, 4, 5, 6, 15, 64704],
            "bindings": [6]
          },
          "2": {
            "clusters": [0, 2, 3, 4, 5, 6, 15, 64704],
